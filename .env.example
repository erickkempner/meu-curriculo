# =============================================================================
# Meu Currículo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked [REQUIRED] must be set before the application starts.
# Variables marked [OPTIONAL] have sensible defaults shown below.

# =============================================================================
# Application
# =============================================================================

# [OPTIONAL] Port the HTTP server listens on
APP_PORT=8080

# [OPTIONAL] Environment mode: development, staging, production
APP_ENV=development

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# [REQUIRED] PostgreSQL host address
DB_HOST=localhost

# [REQUIRED] PostgreSQL port
DB_PORT=5432

# [REQUIRED] PostgreSQL user
DB_USER=curriculo

# [REQUIRED] PostgreSQL password
DB_PASSWORD=curriculo123

# [REQUIRED] PostgreSQL database name
DB_NAME=curriculo_db

# [OPTIONAL] SSL mode for the database connection (disable, require, verify-full)
DB_SSLMODE=disable

# =============================================================================
# Session
# =============================================================================

# [REQUIRED] Secret key used to sign session tokens. Use a long random string in production.
SESSION_SECRET=change-me-in-production

# =============================================================================
# Google OAuth (Optional)
# =============================================================================
# These variables enable "Continue with Google" authentication.
# If left empty or unset, the Google login button will be hidden.

# [OPTIONAL] Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# [OPTIONAL] Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=

# [OPTIONAL] OAuth callback URL (must match Google Cloud Console config)
GOOGLE_REDIRECT_URL=http://localhost:8080/oauth/google/callback

# =============================================================================
# Uploads
# =============================================================================

# [OPTIONAL] Directory for file uploads (photos, etc.)
# Default: ./uploads (local development)
# On Render/containers, use /tmp/uploads since the filesystem may be read-only
UPLOADS_DIR=./uploads
