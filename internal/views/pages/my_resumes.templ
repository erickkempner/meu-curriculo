package pages

import (
	"fmt"
	"github.com/erick/curriculo/internal/models"
	"github.com/erick/curriculo/internal/views/layouts"
)

templ MyResumesWithDataAndUser(resumes []models.Resume, userName string) {
	@layouts.AppLayoutWithUser("Meus Currículos", userName) {
		<div class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8 py-8">
			<!-- Header -->
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
				<div>
					<h1 class="text-2xl font-bold text-gray-900">Meus Currículos</h1>
					<p class="mt-1 text-sm text-gray-500">Gerencie e crie novos currículos</p>
				</div>
				<a
					href="/resumes/new"
					class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 5v14M5 12h14"></path>
					</svg>
					Novo Currículo
				</a>
			</div>
			if len(resumes) > 0 {
				<div id="resumes-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					for _, r := range resumes {
						@ResumeCardWithData(r)
					}
				</div>
			} else {
				<div class="mt-12 text-center">
					<svg xmlns="http://www.w3.org/2000/svg" class="mx-auto size-12 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
					</svg>
					<h3 class="mt-4 text-sm font-medium text-gray-900">Nenhum currículo</h3>
					<p class="mt-1 text-sm text-gray-500">Comece criando seu primeiro currículo profissional.</p>
					<a href="/resumes/new" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 transition">
						Criar primeiro currículo
					</a>
				</div>
			}
			<script>
				async function shareResume(id) {
					try {
						const resp = await fetch('/resumes/' + id + '/share', { method: 'POST' });
						if (resp.ok) {
							const data = await resp.json();
							await navigator.clipboard.writeText(data.share_url);
							showToast('Link copiado para a área de transferência!');
						} else {
							showToast('Erro ao gerar link. Tente novamente.', true);
						}
					} catch(e) {
						showToast('Erro de conexão.', true);
					}
				}

				function showToast(message, isError) {
					const toast = document.createElement('div');
					toast.className = 'fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg transition-all transform translate-y-0 ' + (isError ? 'bg-red-600 text-white' : 'bg-gray-900 text-white');
					toast.textContent = message;
					document.body.appendChild(toast);
					setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
				}
			</script>
		</div>
	}
}

